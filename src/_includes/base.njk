<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title or "Amidama — Apuntes de cine y memoria" }}</title>
<meta name="description" content="{{ description or 'Amidama. Reseñas y notas sobre cine argentino. Memoria, no relleno. Buenos Aires.' }}">
<link rel="icon" href="{{ '/favicon.ico' | url }}" sizes="any">
<link rel="icon" type="image/svg+xml" href="{{ '/favicon.svg' | url }}">
<link rel="icon" type="image/png" sizes="32x32" href="{{ '/favicon-32.png' | url }}">
<link rel="icon" type="image/png" sizes="16x16" href="{{ '/favicon-16.png' | url }}">
<link rel="apple-touch-icon" href="{{ '/apple-touch-icon.png' | url }}">

<meta property="og:type" content="website">
<meta property="og:site_name" content="Amidama">
<meta property="og:title" content="{{ title or 'Amidama — Apuntes de cine y memoria' }}">
<meta property="og:description" content="{{ description or 'Amidama. Reseñas y notas sobre cine argentino. Memoria, no relleno. Buenos Aires.' }}">
<meta property="og:image" content="{{ site.url }}{{ '/og-image.png' | url }}">
<meta property="og:url" content="{{ site.url }}{{ page.url | url }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title or 'Amidama — Apuntes de cine y memoria' }}">
<meta name="twitter:description" content="{{ description or 'Amidama. Reseñas y notas sobre cine argentino. Memoria, no relleno. Buenos Aires.' }}">
<meta name="twitter:image" content="{{ site.url }}{{ '/og-image.png' | url }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Literata:ital,wght@0,400;0,500;0,600;1,400&family=Space+Mono:wght@400;700&family=Bitter:wght@700;800&family=Pinyon+Script&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ '/css/style.css' | url }}">
</head>
<body>

<header class="masthead">
  <div class="wrap">
    <a href="{{ '/' | url }}" class="logo">Amidama</a>
    <nav class="primary">
      <ul>
        <li><a href="{{ '/resenas/' | url }}">Reseñas</a></li>
        <li><a href="{{ '/el-plano/' | url }}">El Plano</a></li>
        <li><a href="{{ '/rescates/' | url }}">Rescates</a></li>
        <li><a href="{{ '/archivo/' | url }}">Archivo</a></li>
        <li><a href="{{ '/sobre/' | url }}">Sobre</a></li>
      </ul>
    </nav>
  </div>
</header>

{{ content | safe }}

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="foot-logo">Amidama</div>
        <p class="foot-note">Apuntes de cine y memoria.</p>
      </div>
      <div class="foot-cols">
        <div class="foot-col">
          <h4>Secciones</h4>
          <a href="{{ '/resenas/' | url }}">Reseñas</a>
          <a href="{{ '/el-plano/' | url }}">El Plano</a>
          <a href="{{ '/rescates/' | url }}">Rescates</a>
          <a href="{{ '/archivo/' | url }}">Archivo</a>
        </div>
        <div class="foot-col">
          <h4>Contacto</h4>
          <p>Dirección editorial: Franco Novo</p>
          <a href="mailto:amidamaprod@gmail.com">amidamaprod@gmail.com</a>
          <a href="https://instagram.com/" target="_blank" rel="noopener">Instagram</a>
        </div>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© {{ currentYear }} AMIDAMA — Buenos Aires</span>
      <span>Medio digital independiente de cine</span>
    </div>
  </div>
</footer>

<script src="{{ '/js/reveal.js' | url }}"></script>
</body>
</html>
