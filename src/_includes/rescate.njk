---
layout: base.njk
---
<section class="review-hero" data-reveal>
  <div class="wrap">
    <div class="review-hero-grid">
      <div class="review-cover" style="{% if image %}background-image:url('{{ image }}');background-size:cover;background-position:center;{% endif %}"></div>
      <div class="review-meta-col">
        <div class="hero-eyebrow">Rescates</div>
        <h1 class="review-title">{{ title }}</h1>
        <div class="tech-line">{{ epoca }}{% if fotografo %} · {{ fotografo }}{% endif %}</div>
        <div class="hero-meta">{{ page.date | readableDate }}</div>
      </div>
    </div>
  </div>
</section>

<main class="wrap">
  <article class="post-body" data-reveal>
    {{ content | safe }}
  </article>
  <p class="back-link"><a href="/rescates/">← Volver a Rescates</a></p>
</main>
